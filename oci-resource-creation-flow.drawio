          <mxGeometry x="10" y="95" width="22" height="22" as="geometry" />
        </mxCell>

        <mxCell id="s2" value="POST /chat received&lt;br/&gt;Set up SSE response stream.&lt;br/&gt;Build messages array:&lt;br/&gt;system_prompt + history + user_msg"
          style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;html=1;arcSize=15;"
          vertex="1" parent="1">
          <mxGeometry x="200" y="103" width="150" height="80" as="geometry" />
        </mxCell>
        <mxCell id="n2" value="2"
          style="ellipse;whiteSpace=wrap;fillColor=#6c8ebf;strokeColor=#4d7caa;fontColor=#ffffff;fontSize=10;fontStyle=1;html=1;"
          vertex="1" parent="1">
          <mxGeometry x="192" y="95" width="22" height="22" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════
             PHASE 2 — DISCOVERY LOOP
        ════════════════════════════════════════ -->
        <mxCell id="ph2" value="DISCOVERY LOOP  (multi-turn, up to 20 turns)"
          style="text;html=1;fontStyle=1;fontSize=10;fillColor=none;strokeColor=none;fontColor=#6c8ebf;align=left;"
          vertex="1" parent="1">
          <mxGeometry x="10" y="202" width="350" height="18" as="geometry" />
        </mxCell>

        <mxCell id="s3" value="Call Anthropic API&lt;br/&gt;&lt;b&gt;model:&lt;/b&gt; claude-opus-4-6&lt;br/&gt;&lt;b&gt;payload:&lt;/b&gt; system_prompt +&lt;br/&gt;22 tool defs + conversation"
          style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;html=1;arcSize=15;"
          vertex="1" parent="1">
          <mxGeometry x="200" y="223" width="150" height="85" as="geometry" />
        </mxCell>
        <mxCell id="n3" value="3"
          style="ellipse;whiteSpace=wrap;fillColor=#6c8ebf;strokeColor=#4d7caa;fontColor=#ffffff;fontSize=10;fontStyle=1;html=1;"
          vertex="1" parent="1">
          <mxGeometry x="192" y="215" width="22" height="22" as="geometry" />
        </mxCell>

        <mxCell id="s4" value="Analyze request.&lt;br/&gt;Decides: must discover valid&lt;br/&gt;ADs · images · shapes first.&lt;br/&gt;&lt;b&gt;stop_reason = tool_use&lt;/b&gt;&lt;br/&gt;Returns 3 discovery tool_use blocks"
          style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;html=1;arcSize=15;"
          vertex="1" parent="1">
          <mxGeometry x="593" y="223" width="169" height="95" as="geometry" />
        </mxCell>
        <mxCell id="n4" value="4"
          style="ellipse;whiteSpace=wrap;fillColor=#b85450;strokeColor=#963b30;fontColor=#ffffff;fontSize=10;fontStyle=1;html=1;"
          vertex="1" parent="1">
          <mxGeometry x="585" y="215" width="22" height="22" as="geometry" />
        </mxCell>

        <mxCell id="s5" value="For each tool_use block:&lt;br/&gt;callOCIToolViaMCP()&lt;br/&gt;SSE → browser: &lt;i&gt;tool_call&lt;/i&gt; event&lt;br/&gt;(user sees live progress)"
          style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;html=1;arcSize=15;"
          vertex="1" parent="1">
          <mxGeometry x="200" y="353" width="150" height="80" as="geometry" />
        </mxCell>
        <mxCell id="n5" value="5"
          style="ellipse;whiteSpace=wrap;fillColor=#6c8ebf;strokeColor=#4d7caa;fontColor=#ffffff;fontSize=10;fontStyle=1;html=1;"
          vertex="1" parent="1">
          <mxGeometry x="192" y="345" width="22" height="22" as="geometry" />
        </mxCell>

        <mxCell id="s6" value="InMemoryTransport&lt;br/&gt;(in-process, no HTTP)&lt;br/&gt;MCP Server validates tool.&lt;br/&gt;Routes to:&lt;br/&gt;IdentityService / ComputeService"
          style="rounded=1;whiteSpace=wrap;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;html=1;arcSize=15;"
          vertex="1" parent="1">
          <mxGeometry x="390" y="353" width="150" height="90" as="geometry" />
        </mxCell>
        <mxCell id="n6" value="6"
          style="ellipse;whiteSpace=wrap;fillColor=#6c8ebf;strokeColor=#4d7caa;fontColor=#ffffff;fontSize=10;fontStyle=1;html=1;"
          vertex="1" parent="1">
          <mxGeometry x="382" y="345" width="22" height="22" as="geometry" />
        </mxCell>

        <mxCell id="s7" value="HTTPS GET (RSA signed):&lt;br/&gt;• list_availability_domains&lt;br/&gt;• list_images (OS filter)&lt;br/&gt;• list_shapes&lt;br/&gt;&lt;br/&gt;Returns: AD names,&lt;br/&gt;image OCIDs, shape specs"
          style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;html=1;arcSize=15;"
          vertex="1" parent="1">
          <mxGeometry x="800" y="343" width="150" height="110" as="geometry" />
        </mxCell>
        <mxCell id="n7" value="7"
          style="ellipse;whiteSpace=wrap;fillColor=#d6b656;strokeColor=#b8983a;fontColor=#333333;fontSize=10;fontStyle=1;html=1;"
          vertex="1" parent="1">
          <mxGeometry x="792" y="335" width="22" height="22" as="geometry" />
        </mxCell>

        <mxCell id="s8" value="JSON results appended as&lt;br/&gt;tool_result blocks.&lt;br/&gt;SSE → browser: &lt;i&gt;tool_result&lt;/i&gt; events.&lt;br/&gt;Loop: next Claude API turn."
          style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;html=1;arcSize=15;"
          vertex="1" parent="1">
          <mxGeometry x="200" y="478" width="150" height="80" as="geometry" />
        </mxCell>
        <mxCell id="n8" value="8"
          style="ellipse;whiteSpace=wrap;fillColor=#6c8ebf;strokeColor=#4d7caa;fontColor=#ffffff;fontSize=10;fontStyle=1;html=1;"
          vertex="1" parent="1">
          <mxGeometry x="192" y="470" width="22" height="22" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════
             PHASE 3 — CONFIRMATION
        ════════════════════════════════════════ -->
        <mxCell id="ph3" value="CONFIRMATION"
          style="text;html=1;fontStyle=1;fontSize=10;fillColor=none;strokeColor=none;fontColor=#6c8ebf;align=left;"
          vertex="1" parent="1">
          <mxGeometry x="10" y="582" width="160" height="18" as="geometry" />
        </mxCell>

        <mxCell id="s9" value="Has valid AD · image OCID · shape.&lt;br/&gt;Builds creation plan:&lt;br/&gt;name · shape · cost notes · tags.&lt;br/&gt;&lt;b&gt;stop_reason = end_turn&lt;/b&gt;&lt;br/&gt;&lt;i&gt;&quot;Shall I proceed? (yes/no)&quot;&lt;/i&gt;"
          style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;html=1;arcSize=15;"
          vertex="1" parent="1">
          <mxGeometry x="593" y="600" width="169" height="100" as="geometry" />
        </mxCell>
        <mxCell id="n9" value="9"
          style="ellipse;whiteSpace=wrap;fillColor=#b85450;strokeColor=#963b30;fontColor=#ffffff;fontSize=10;fontStyle=1;html=1;"
          vertex="1" parent="1">
          <mxGeometry x="585" y="592" width="22" height="22" as="geometry" />
        </mxCell>

        <mxCell id="s10" value="SSE text deltas → browser.&lt;br/&gt;Sends &lt;i&gt;done&lt;/i&gt; event with&lt;br/&gt;full response + trimmed history."
          style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;html=1;arcSize=15;"
          vertex="1" parent="1">
          <mxGeometry x="200" y="620" width="150" height="70" as="geometry" />
        </mxCell>
        <mxCell id="n10" value="10"
          style="ellipse;whiteSpace=wrap;fillColor=#6c8ebf;strokeColor=#4d7caa;fontColor=#ffffff;fontSize=10;fontStyle=1;html=1;"
          vertex="1" parent="1">
          <mxGeometry x="192" y="612" width="22" height="22" as="geometry" />
        </mxCell>

        <mxCell id="s11" value="Display plan to user:&lt;br/&gt;name · shape · image&lt;br/&gt;subnet · cost · tags"
          style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;html=1;arcSize=15;"
          vertex="1" parent="1">
          <mxGeometry x="18" y="625" width="150" height="65" as="geometry" />
        </mxCell>
        <mxCell id="n11" value="11"
          style="ellipse;whiteSpace=wrap;fillColor=#6c8ebf;strokeColor=#4d7caa;fontColor=#ffffff;fontSize=10;fontStyle=1;html=1;"
          vertex="1" parent="1">
          <mxGeometry x="10" y="617" width="22" height="22" as="geometry" />
        </mxCell>

        <!-- Decision diamond -->
        <mxCell id="d1" value="&lt;b&gt;User confirms?&lt;/b&gt;"
          style="rhombus;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;html=1;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="28" y="720" width="130" height="65" as="geometry" />
        </mxCell>
        <mxCell id="n12" value="12"
          style="ellipse;whiteSpace=wrap;fillColor=#9673a6;strokeColor=#7a5c8a;fontColor=#ffffff;fontSize=10;fontStyle=1;html=1;"
          vertex="1" parent="1">
          <mxGeometry x="20" y="712" width="22" height="22" as="geometry" />
        </mxCell>

        <!-- NO terminus -->
        <mxCell id="s-no" value="No resource created.&lt;br/&gt;Conversation ends."
          style="rounded=1;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontSize=10;html=1;"
          vertex="1" parent="1">
          <mxGeometry x="28" y="825" width="130" height="45" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════
             PHASE 4 — CREATION
        ════════════════════════════════════════ -->
        <mxCell id="ph4" value="RESOURCE CREATION"
          style="text;html=1;fontStyle=1;fontSize=10;fillColor=none;strokeColor=none;fontColor=#6c8ebf;align=left;"
          vertex="1" parent="1">
          <mxGeometry x="185" y="728" width="200" height="18" as="geometry" />
        </mxCell>

        <mxCell id="s12" value="User types &lt;b&gt;&quot;yes&quot;&lt;/b&gt;.&lt;br/&gt;POST /chat&lt;br/&gt;{message: &apos;yes&apos;, history}"
          style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;html=1;arcSize=15;"
          vertex="1" parent="1">
          <mxGeometry x="200" y="748" width="150" height="65" as="geometry" />
        </mxCell>
        <mxCell id="n13" value="13"
          style="ellipse;whiteSpace=wrap;fillColor=#6c8ebf;strokeColor=#4d7caa;fontColor=#ffffff;fontSize=10;fontStyle=1;html=1;"
          vertex="1" parent="1">
          <mxGeometry x="192" y="740" width="22" height="22" as="geometry" />
        </mxCell>

        <mxCell id="s13" value="User confirmed.&lt;br/&gt;Calls compute__create_instance&lt;br/&gt;with all discovered params.&lt;br/&gt;&lt;b&gt;stop_reason = tool_use&lt;/b&gt;"
          style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;html=1;arcSize=15;"
          vertex="1" parent="1">
          <mxGeometry x="593" y="748" width="169" height="85" as="geometry" />
        </mxCell>
        <mxCell id="n14" value="14"
          style="ellipse;whiteSpace=wrap;fillColor=#b85450;strokeColor=#963b30;fontColor=#ffffff;fontSize=10;fontStyle=1;html=1;"
          vertex="1" parent="1">
          <mxGeometry x="585" y="740" width="22" height="22" as="geometry" />
        </mxCell>

        <mxCell id="s14" value="callOCIToolViaMCP(&lt;br/&gt;&quot;compute__create_instance&quot;,&lt;br/&gt;{display_name, shape,&lt;br/&gt;image_id, subnet_id, AD})&lt;br/&gt;SSE → browser: &lt;i&gt;tool_call&lt;/i&gt; event"
          style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;html=1;arcSize=15;"
          vertex="1" parent="1">
          <mxGeometry x="200" y="873" width="150" height="95" as="geometry" />
        </mxCell>
        <mxCell id="n15" value="15"
          style="ellipse;whiteSpace=wrap;fillColor=#6c8ebf;strokeColor=#4d7caa;fontColor=#ffffff;fontSize=10;fontStyle=1;html=1;"
          vertex="1" parent="1">
          <mxGeometry x="192" y="865" width="22" height="22" as="geometry" />
        </mxCell>

        <mxCell id="s15" value="InMemoryTransport&lt;br/&gt;MCP Server dispatches to&lt;br/&gt;ComputeService.createInstance()"
          style="rounded=1;whiteSpace=wrap;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;html=1;arcSize=15;"
          vertex="1" parent="1">
          <mxGeometry x="390" y="888" width="150" height="70" as="geometry" />
        </mxCell>
        <mxCell id="n16" value="16"
          style="ellipse;whiteSpace=wrap;fillColor=#6c8ebf;strokeColor=#4d7caa;fontColor=#ffffff;fontSize=10;fontStyle=1;html=1;"
          vertex="1" parent="1">
          <mxGeometry x="382" y="880" width="22" height="22" as="geometry" />
        </mxCell>

        <mxCell id="s16" value="HTTPS POST (RSA signed)&lt;br/&gt;→ OCI Compute API&lt;br/&gt;&lt;b&gt;LaunchInstance&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;Returns:&lt;br/&gt;OCID: &lt;i&gt;ocid1.instance...&lt;/i&gt;&lt;br/&gt;lifecycleState: PROVISIONING"
          style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;html=1;arcSize=15;"
          vertex="1" parent="1">
          <mxGeometry x="800" y="873" width="150" height="110" as="geometry" />
        </mxCell>
        <mxCell id="n17" value="17"
          style="ellipse;whiteSpace=wrap;fillColor=#d6b656;strokeColor=#b8983a;fontColor=#333333;fontSize=10;fontStyle=1;html=1;"
          vertex="1" parent="1">
          <mxGeometry x="792" y="865" width="22" height="22" as="geometry" />
        </mxCell>

        <mxCell id="s17" value="Append tool_result:&lt;br/&gt;OCID + PROVISIONING state.&lt;br/&gt;SSE → browser: &lt;i&gt;tool_result&lt;/i&gt;.&lt;br/&gt;Next (final) Claude API turn."
          style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;html=1;arcSize=15;"
          vertex="1" parent="1">
          <mxGeometry x="200" y="1013" width="150" height="80" as="geometry" />
        </mxCell>
        <mxCell id="n18" value="18"
          style="ellipse;whiteSpace=wrap;fillColor=#6c8ebf;strokeColor=#4d7caa;fontColor=#ffffff;fontSize=10;fontStyle=1;html=1;"
          vertex="1" parent="1">
          <mxGeometry x="192" y="1005" width="22" height="22" as="geometry" />
        </mxCell>

        <mxCell id="s18" value="Compose success message:&lt;br/&gt;&lt;i&gt;&quot;✅ Instance created!&lt;br/&gt;OCID: ocid1.instance...&lt;br/&gt;State: PROVISIONING&lt;br/&gt;→ RUNNING shortly&quot;&lt;/i&gt;&lt;br/&gt;&lt;b&gt;stop_reason = end_turn&lt;/b&gt;"
          style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;html=1;arcSize=15;"
          vertex="1" parent="1">
          <mxGeometry x="593" y="1003" width="169" height="100" as="geometry" />
        </mxCell>
        <mxCell id="n19" value="19"
          style="ellipse;whiteSpace=wrap;fillColor=#b85450;strokeColor=#963b30;fontColor=#ffffff;fontSize=10;fontStyle=1;html=1;"
          vertex="1" parent="1">
          <mxGeometry x="585" y="995" width="22" height="22" as="geometry" />
        </mxCell>

        <mxCell id="s19" value="SSE &lt;i&gt;done&lt;/i&gt; event with&lt;br/&gt;full text + updated history"
          style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;html=1;arcSize=15;"
          vertex="1" parent="1">
          <mxGeometry x="200" y="1133" width="150" height="55" as="geometry" />
        </mxCell>
        <mxCell id="n20" value="20"
          style="ellipse;whiteSpace=wrap;fillColor=#6c8ebf;strokeColor=#4d7caa;fontColor=#ffffff;fontSize=10;fontStyle=1;html=1;"
          vertex="1" parent="1">
          <mxGeometry x="192" y="1125" width="22" height="22" as="geometry" />
        </mxCell>

        <mxCell id="s20" value="✅ Display result:&lt;br/&gt;&lt;i&gt;&quot;Instance created!&lt;br/&gt;OCID: ocid1.instance...&lt;br/&gt;State: PROVISIONING&quot;&lt;/i&gt;"
          style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;html=1;arcSize=15;"
          vertex="1" parent="1">
          <mxGeometry x="18" y="1133" width="150" height="75" as="geometry" />
        </mxCell>
        <mxCell id="n21" value="21"
          style="ellipse;whiteSpace=wrap;fillColor=#6c8ebf;strokeColor=#4d7caa;fontColor=#ffffff;fontSize=10;fontStyle=1;html=1;"
          vertex="1" parent="1">
          <mxGeometry x="10" y="1125" width="22" height="22" as="geometry" />
        </mxCell>

        <!-- END terminal -->
        <mxCell id="end-node" value="END"
          style="ellipse;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=12;html=1;"
          vertex="1" parent="1">
          <mxGeometry x="53" y="1240" width="80" height="40" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════
             EDGES
