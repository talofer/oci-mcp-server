        ════════════════════════════════════════ -->
        <mxCell id="ph1" value="REQUEST"
          style="text;html=1;fontStyle=1;fontSize=10;fillColor=none;strokeColor=none;fontColor=#6c8ebf;align=left;"
          vertex="1" parent="1">
          <mxGeometry x="10" y="82" width="120" height="18" as="geometry" />
        </mxCell>

        <mxCell id="s1" value="User types natural-language request&lt;br/&gt;&lt;i&gt;&quot;Create a compute instance&lt;br/&gt;named dev-web-01&quot;&lt;/i&gt;"
          style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;html=1;arcSize=15;"
          vertex="1" parent="1">
          <mxGeometry x="18" y="103" width="150" height="70" as="geometry" />
