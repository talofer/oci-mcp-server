          vertex="1" parent="1">
          <mxGeometry x="1020" y="1090" width="340" height="60" as="geometry" />
        </mxCell>

        <mxCell id="legend-solid" value="Solid arrow = HTTP/HTTPS request"
          style="text;html=1;fontSize=10;align=left;"
          vertex="1" parent="legend">
          <mxGeometry x="10" y="30" width="200" height="20" as="geometry" />
