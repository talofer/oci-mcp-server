    <mxCell id="streamhttp" value="&lt;b&gt;StreamableHTTPServerTransport&lt;/b&gt;&lt;br/&gt;&lt;font style=&apos;font-size:10px&apos;&gt;Per-request instance&lt;br/&gt;Handles POST /mcp requests&lt;/font&gt;"
      style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;whiteSpace=wrap;html=1;fontSize=11;"
      vertex="1" parent="1">
      <mxGeometry x="672" y="614" width="208" height="60" as="geometry" />
