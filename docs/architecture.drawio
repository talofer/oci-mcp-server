    <mxCell id="inmem" value="&lt;b&gt;InMemoryTransport (linked pair)&lt;/b&gt;&lt;br/&gt;&lt;font style=&apos;font-size:10px&apos;&gt;serverTransport ↔ clientTransport&lt;br/&gt;Zero-overhead in-process IPC&lt;/font&gt;"
      style="rounded=1;fillColor=#ffe6cc;strokeColor=#d79b00;whiteSpace=wrap;html=1;fontSize=11;"
      vertex="1" parent="1">
