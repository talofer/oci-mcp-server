      style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;whiteSpace=wrap;html=1;fontSize=11;"
      vertex="1" parent="1">
      <mxGeometry x="604" y="330" width="185" height="95" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════════════
         CHAT HANDLER
    ═══════════════════════════════════════════════════════════════════ -->

    <mxCell id="chathandler" value="&lt;b&gt;src/chat/handler.ts — handleChat(message, history, res)&lt;/b&gt;&lt;br/&gt;&lt;font style=&apos;font-size:10px&apos;&gt;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&lt;br/&gt;① Set SSE response headers (text/event-stream)&lt;br/&gt;② Build messages = [...history, { role: user, content: message }]&lt;br/&gt;③ AGENTIC LOOP (max 20 turns):&lt;br/&gt;&amp;nbsp;&amp;nbsp;a. stream = client.messages.stream(model, tools, messages)&lt;br/&gt;&amp;nbsp;&amp;nbsp;b. stream.on(&apos;text&apos;) → emit SSE event: &apos;text&apos; { delta }&lt;br/&gt;&amp;nbsp;&amp;nbsp;c. stop_reason = &apos;end_turn&apos;:&lt;br/&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;→ emit SSE event: &apos;done&apos; { text, history[-30:] }  BREAK&lt;br/&gt;&amp;nbsp;&amp;nbsp;d. stop_reason = &apos;tool_use&apos;: (for each tool block)&lt;br/&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;→ emit SSE event: &apos;tool_call&apos; { id, name, input }&lt;br/&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;→ callOCIToolViaMCP(name, args) [MCP protocol]&lt;br/&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;→ emit SSE event: &apos;tool_result&apos; or &apos;tool_error&apos;&lt;br/&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;→ append tool_result(s) to messages  CONTINUE&lt;br/&gt;&amp;nbsp;&amp;nbsp;e. stop_reason = &apos;pause_turn&apos;: CONTINUE&lt;br/&gt;④ On Anthropic error → emit SSE event: &apos;error&apos; { message }&lt;br/&gt;⑤ finally: res.end()&lt;/font&gt;"
      style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;whiteSpace=wrap;html=1;fontSize=11;align=left;spacingLeft=8;spacingRight=6;"
      vertex="1" parent="1">
      <mxGeometry x="30" y="463" width="390" height="227" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════════════
