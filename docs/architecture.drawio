    <mxCell id="mcpclient" value="&lt;b&gt;In-process MCP Client&lt;/b&gt;&lt;br/&gt;&lt;font style=&apos;font-size:10px&apos;&gt;getMCPClient() — lazy singleton&lt;br/&gt;name: oci-chat-client v0.1.0&lt;br/&gt;─────────────────────────&lt;br/&gt;callOCIToolViaMCP(name, args)&lt;br/&gt;→ client.callTool()&lt;br/&gt;→ JSON.parse(text result)&lt;/font&gt;"
      style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;whiteSpace=wrap;html=1;fontSize=11;"
      vertex="1" parent="1">
