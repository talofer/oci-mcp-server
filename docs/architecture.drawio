    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════════════
         STARTUP / DOC CHECKER
    ═══════════════════════════════════════════════════════════════════ -->

    <mxCell id="docchecker" value="&lt;b&gt;src/utils/doc-checker.ts — checkOCIDocsForUpdates()&lt;/b&gt;&lt;br/&gt;&lt;font style=&apos;font-size:10px&apos;&gt;• Parallel HEAD requests to 5 OCI docs URLs (8s timeout each)&lt;br/&gt;• Compare Last-Modified header vs stored value in JSON cache&lt;br/&gt;• First run: record baseline (no alert)&lt;br/&gt;• Changed: LOG WARN with URL + &quot;Review OCI_SYSTEM_PROMPT&quot; action&lt;br/&gt;• Unchanged: LOG DEBUG per page, LOG INFO &quot;all up to date ✓&quot;&lt;br/&gt;• Error/timeout: silently treat as unchanged (non-blocking)&lt;/font&gt;"
      style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;whiteSpace=wrap;html=1;fontSize=11;align=left;spacingLeft=6;"
      vertex="1" parent="1">
      <mxGeometry x="940" y="203" width="430" height="130" as="geometry" />
    </mxCell>

    <mxCell id="tracked_docs" value="&lt;b&gt;5 Tracked Documentation Pages:&lt;/b&gt;&lt;br/&gt;&lt;font style=&apos;font-size:10px&apos;&gt;• OCI Well-Architected Framework&lt;br/&gt;• OCI Compute Best Practices&lt;br/&gt;• OCI Security Guide&lt;br/&gt;• OCI Networking Best Practices&lt;br/&gt;• OCI Cost Management Best Practices&lt;/font&gt;"
      style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;whiteSpace=wrap;html=1;fontSize=11;align=left;spacingLeft=6;"
      vertex="1" parent="1">
