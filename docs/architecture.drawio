    ═══════════════════════════════════════════════════════════════════ -->

    <mxCell id="mcpserver" value="&lt;b&gt;MCP Server&lt;/b&gt; (mcpServer)&lt;br/&gt;&lt;font style=&apos;font-size:10px&apos;&gt;name: oci-mcp-server v0.1.0&lt;br/&gt;capabilities: { tools: {} }&lt;br/&gt;─────────────────────────&lt;br/&gt;ListTools → MCP_TOOLS[22]&lt;br/&gt;CallTool → executeOCITool()&lt;br/&gt;→ dispatch to service class&lt;/font&gt;"
      style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;whiteSpace=wrap;html=1;fontSize=11;"
      vertex="1" parent="1">
