{
  "name": "mcp-server-oci",
  "version": "0.1.0",
  "description": "Model Context Protocol server for Oracle Cloud Infrastructure",
  "main": "dist/electron/main.js",
  "bin": {
    "mcp-server-oci": "./dist/cli.js"
  },
  "scripts": {
    "build:server": "tsc -p tsconfig.json",
    "build:electron": "node scripts/bundle-electron.cjs",
    "build": "npm run build:server && npm run build:electron",
    "dev": "ts-node-dev --respawn --transpile-only src/cli.ts",
    "start": "node dist/cli.js",
    "electron:dev": "npm run build:server && tsc -p tsconfig.electron.json && electron .",
    "electron:build": "npm run build && node scripts/package-win.cjs",
    "lint": "eslint . --ext .ts",
    "test": "jest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "oracle",
    "cloud",
    "claude",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "build": {
    "appId": "com.talofer.oci-mcp-server",
    "productName": "OCI MCP Server",
    "directories": {
      "output": "installer"
    },
    "files": [
      "dist/electron/main.js",
      "public/**/*",
      "package.json"
    ],
    "win": {
      "target": "dir",
      "forceCodeSigning": false
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "oci-sdk": "^2.66.0",
    "winston": "^3.11.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.9.4",
    "@types/yargs": "^17.0.32",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "@typescript-eslint/parser": "^6.12.0",
    "cross-env": "^10.1.0",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.4",
    "eslint": "^8.54.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.2"
  }
}
